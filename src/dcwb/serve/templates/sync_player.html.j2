{% extends "base.html.j2" %}
{% block title %}sync {{ date }}{% endblock %}
{% block content %}
<h1>Insta360 × Tesla sync — {{ date }}</h1>
<div style="display:flex;gap:8px">
  <video id="insta" controls style="width:50%"></video>
  <video id="tesla" controls muted style="width:50%"></video>
</div>
<div>
  <label>nudge Δ (s, Tesla leads): <span id="dval"></span></label>
  <input id="nudge" type="range" min="-120" max="120" step="0.1" style="width:100%">
  <p id="meta"></p>
</div>
<script>
const date = "{{ date }}";
const insta = document.getElementById('insta'), tesla = document.getElementById('tesla');
const nudge = document.getElementById('nudge'), dval = document.getElementById('dval');
let delta = 0;
const base = p => p.split('/').pop();
fetch(`/sync-data/${date}`).then(r => r.json()).then(m => {
  delta = m.delta_s; nudge.value = delta; dval.textContent = delta.toFixed(2);
  insta.src = `/sync-video/${date}/${base(m.paths.insta_display)}`;
  tesla.src = `/sync-video/${date}/${base(m.paths.tesla_concat)}`;
  document.getElementById('meta').textContent =
    `signal ${m.signal}  confidence ${m.confidence.toFixed(3)}`;
});
insta.addEventListener('timeupdate', () => {
  const t = insta.currentTime + delta;
  if (Math.abs(tesla.currentTime - t) > 0.15 && isFinite(t)) tesla.currentTime = Math.max(0, t);
});
insta.addEventListener('play', () => tesla.play());
insta.addEventListener('pause', () => tesla.pause());
nudge.addEventListener('input', () => { delta = parseFloat(nudge.value); dval.textContent = delta.toFixed(2); });
nudge.addEventListener('change', () => fetch(`/sync-nudge/${date}`, {
  method: 'POST', headers: {'Content-Type': 'application/json'},
  body: JSON.stringify({delta_s: delta})
}));
</script>
{% endblock %}
