<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>{% block title %}dcwb{% endblock %}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="{{ url_for('static', filename='app.css') }}">
</head>
<body>
  <header>
    <a href="{{ url_for('root') }}" class="brand">dcwb</a>
    <form action="{{ url_for('reindex') }}" method="post" class="reindex">
      <button type="submit">Reindex</button>
    </form>
  </header>
  <main>
    {% block content %}{% endblock %}
  </main>
</body>
</html>
